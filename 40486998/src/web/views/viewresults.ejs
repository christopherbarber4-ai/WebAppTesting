<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/mini.css/3.0.1/mini-default.min.css">
  <link rel="stylesheet" href="myuis.css">
  <title>Award Calc</title>
</head>

<body>

  <header>
    <div class="brandedLogo">
      <img src="/media/logo2.jpg" id="logo" />
    </div>
    <a href="/landing" class="logo">HEDClass</a>
    <% if(userAccessLevel==="officer(view)" || userAccessLevel==="officer(edit)" ) { %>

      <a href="/dashboard" class="button">Dashboard</a>
      <a href="/studentmgmt" class="button">Student Management</a>
      <% } %>
        <% if(userAccessLevel==="admin" ) { %>
          <a href="/officermgmt" class="button"> Officer Management </a>
          <a href="/coursemgmt" class="button"> Course Management</a>
          <% } %>
            <% if(userAccessLevel==="officer(view)" || userAccessLevel==="officer(edit)" ) { %>
              <a href="/resultsmgmt" class="button"> Results Management</a>
              <% } %>
                <% if(userAccessLevel==="officer(view)" || userAccessLevel==="officer(edit)" ||
                  userAccessLevel==="admin" ) { %>
                  <a href="/logout" class="button">Logout</a>
                  <% } %>

                    <button> ( logged in as <Strong>
                        <%= userAccessLevel %>
                      </Strong>) </button>
  </header>
  <table>
    <tbody>
      <%totalResults.forEach((result)=>{ %>
        <tr>
          <td> <b>First name:</b>
            <%= result.firstName %> <br>
          </td>
          <td> <b>Second name:</b>
            <%= result.lastName %> <br>
          </td>
          <td> <b>Email:</b>
            <%= result.email %> <br>
          </td>
          <td> <b>Module Name:</b>
            <%= result.moduleName %> <br>
          </td>
          <td> <b>Module Id:</b>
            <%= result.moduleID %> <br>
          </td>
          <td> <b>Credit Value:</b>
            <%= result.creditValue %> <br>
          </td>
          <td> <b>Score:</b>
            <%= result.score %> <br>
          </td>
          <td> <b>Resit?:</b>
            <% if (result.resit===1){ %>
              Yes <% } else {%> No <% } %><br>
          </td>
        </tr>
        <% }); %>
    </tbody>
  </table>

  <% if(userAccessLevel==="officer(edit)" ) { %>



    <p>To add a new result, please fill out all fields...</p>

    <div class="resultForm">
      <form action="/addresult" method="POST">
        <div>
          StudentId: <input type="text" name="studentId" readonly value="<%=student[0].id %> ">
        </div>
        <div>
          CourseId: <input type="text" name="courseId" readonly value="<%=student[0].courseID %>">
        </div>
        <div>
          First Name: <input type="text" name="studentFirstName" readonly value="<%=student[0].firstName %>" required>
        </div>
        <div>
          Last Name: <input type="text" name="studentLastName" readonly value="<%=student[0].lastName %>" required>
        </div>
        <div>
          Module Name: <select name="studentModule" required>
            <% courses.forEach ((course)=> {%>
              <option value="<%= course.moduleID%>" <% if (course.moduleID===course.moduleID) {%>
                selected <% } %> >
                  <%= course.moduleName%>
              </option>
              <%}); %>
                </option>
          </select>
        </div>
        <div>
          Module Result: <input type="number" step="0.01" name="moduleScore" value="0" min="0" max="100" required>
        </div>
        <div>
          Resit?: <select name="isResit" required>
            <option value=1> Yes </option>
            <option value=0> No </option>
          </select>
        </div>

        <div>
          <button>Add Result</button>
        </div>

      </form>

      <form action="/addclassification" method="POST">
        <div>
          StudentId: <input type="text" name="studentId" readonly value="<%=student[0].id %>">
        </div>
        <div>
          <button>Add Classification</button>
        </div>
      </form>
</body>

<% } %>

</html>