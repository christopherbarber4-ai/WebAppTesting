<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/mini.css/3.0.1/mini-default.min.css">
    <link rel="stylesheet" href="/myuis.css">
    <title>Edit Student</title>
</head>

      <header>

        <a href="/landing" class="logo">HEdClass</a>
        <% if(userAccessLevel==="officer(view)" || userAccessLevel==="officer(edit)" ) { %>

          <a href="/dashboard" class="button">Dashboard</a>
          <a href="/studentmgmt" class="button">Student Management</a>
          <% } %>
            <% if(userAccessLevel==="admin" ) { %>
              <a href="/officermgmt" class="button"> Officer Management </a>
              <% } %>
                <% if(userAccessLevel==="officer(edit)" || userAccessLevel === "admin" ) { %>
                  <a href="/coursemgmt" class="button"> Course Management</a>
                  <%}%>
                    <% if(userAccessLevel==="officer(view)" || userAccessLevel==="officer(edit)" ||
                      userAccessLevel==="admin" ) { %>
                      <a href="/logout" class="button">Logout</a>
                      <% } %>

                        <button> ( logged in as <Strong>
                            <%= userAccessLevel %>
                          </Strong>) </button>
      </header>


    <p>
        To delete a Student record, please confirm below
    </p>
    <hr>

<body>

    <form action="/deletestudent" method="POST">
        <p>
        <div>
            User id: <input type="text" name="studentid" readonly value="<%=student[0].id %>">
        </div>
        <div>
            Student First Name: <input type="text" name="studentFirstName" readonly value="<%=student[0].firstName %>">
        </div>
        <div>
            Student Last Name: <input type="text" name="studentLastName" readonly value="<%=student[0].lastName %>">
        </div>
        <div>
            Student email address: <input type="text" name="studentEmail" readonly value="<%=student[0].email %>">
        </div>
        <div>
            Graduation Year: <input type="text" name="studentGradYr" readonly value="<%=student[0].graduationYear %>">
        </div>
 
        </p>
        <input type="submit" value="DELETE" onclick="return confirm('Are you sure?')">
    </form>


</body>

</html>