<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/mini.css/3.0.1/mini-default.min.css">
  <title>HedClass</title>
</head>

<body>

  <header>
    <a href="/landing" class="logo">HEDclass</a>
    <a href="/dashboard" class="button">Dashboard</a>
    <a href="/studentmgmt" class="button">Student Management</a>
    <a href="/officermgmt" class="button"> Officer Management </a>
    <a href = "/coursemgmt" class="button"> Course Management</a>
    <a href ="/resultsmgmt" class="button"> Results Management</a>
    <a href="/logout" class="button">Logout</a>

  </header>
<h2> WELCOME TO THE DASHBOARD!!</h2>

        <hr>
       
    <table>
    <tbody>      
    <%uniqueCourses.forEach((course)=>{ %>
    <tr>
 
  
    <td> Course Name: <%= course.title %></td>
    <td> Total Number of Students: <%= studentStats[course.courseID].totalStudents %></td>
    <td> Number of Firsts:<%= studentStats[course.courseID].gradeFirst %></td>
    <td> Number of 2:1s: <%= studentStats[course.courseID].gradeTwoOne %></td>
    <td> Number of 2:2s: <%= studentStats[course.courseID].gradeTwoTwo %></td>
    <td> Number of Thirds: <%= studentStats[course.courseID].gradeThird %></td>
    <td> Number of Fails: <%= studentStats[course.courseID].gradeFail%></td>
    </tr>
 <% }); %>
  </tbody>
</table>

</body>

</html>