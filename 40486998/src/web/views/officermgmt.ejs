<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/mini.css/3.0.1/mini-default.min.css">
    <link rel="stylesheet" href="myuis.css">
    <title>Officer Management</title>
</head>

<body>

    <header>
        <div class="brandedLogo">
            <img src="/media/logo2.jpg" id="logo" />
        </div>
        <a href="/landing" class="logo">HEDClass</a>
        <% if(userAccessLevel==="officer(view)" || userAccessLevel==="officer(edit)" ) { %>

            <a href="/dashboard" class="button">Dashboard</a>
            <a href="/studentmgmt" class="button">Student Management</a>
            <% } %>
                <% if(userAccessLevel==="admin" ) { %>
                    <a href="/officermgmt" class="button"> Officer Management </a>
                    <a href="/coursemgmt" class="button"> Course Management</a>
                    <% } %>
                        <% if(userAccessLevel==="officer(view)" || userAccessLevel==="officer(edit)" ) { %>
                            <a href="/resultsmgmt" class="button"> Results Management</a>
                            <% } %>
                                <% if(userAccessLevel==="officer(view)" || userAccessLevel==="officer(edit)" ||
                                    userAccessLevel==="admin" ) { %>
                                    <a href="/logout" class="button">Logout</a>
                                    <% } %>

                                        <button> ( logged in as <Strong>
                                                <%= userAccessLevel %>
                                            </Strong>) </button>
    </header>

    <table>
        <tbody>
            <%users.forEach((user)=>{ %>
                <tr>

                    <td> <b>first name:</b>
                        <%= user.firstName %>
                    </td>
                    <td> <b>second name:</b>
                        <%= user.lastName %> <br>
                    </td>
                    <td> <b>email:</b>
                        <%= user.email %><br>
                    </td>
                    <td> <b>role:</b>
                        <%= user.role %><br>
                    </td>
                    <td> <b>courses:</b>
                        <% user.courses.forEach((course)=> { %>
                            <%= course %>,<br>
                                <% }); %>
                    </td>
                    <td> <a href="/editofficer/<%=user.id%>"> Edit </a></td>
                    <td> <a href="/deleteofficer/<%=user.id%>"> Delete </a></td>


                </tr>
                <% }); %>
        </tbody>
    </table>


    <p>To create a new officer, please fill out all fields...</p>

    <div class="officerForm">
        <form action="/addofficer" method="post">
            <div>
                First Name: <input name="officerFirstName" required>
            </div>
            <div>
                Last Name: <input name="officerLastName" required>
            </div>
            <div>
                Email: <input name="officerEmail" required>
            </div>
            <div>
                Role: <select name="officerRole" required>
                    <option value="admin">Admin</option>
                    <option value="officer(view)">Officer (View)</option>
                    <option value="officer(edit)">Officer (Edit)</option>
                </select>
            </div>
            <div>
                Password: <input name="officerPassword" required>
            </div>
            <div>
                Course: <select name="officerCourseName" required>
                    <% courses.forEach ((course)=> {%>
                        <option value="<%= course.id%>">
                            <%= course.title%>
                        </option>
                        <%}); %>
                </select>
            </div>

            <div>
                <button>Add Officer</button>
            </div>
        </form>
    </div>


</body>

</html>